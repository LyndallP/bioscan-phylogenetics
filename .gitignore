# Large sequence files
*.fasta
*.fa
*.fna
*.fastq
*.fq
*.newick
*.nwk
*.treefile
*.tree
*.jplace
*.json

# Data files
*.csv
*.tsv
*.txt
*.dat

# EXCEPT examples
!*_example.csv
!*_example.tsv
!template/*.csv

# Allow data/ outputs for GitHub Pages / Taxonium
!data/**/*.tsv
!data/**/*.newick

# RAxML outputs
*.raxml.*
RAxML_*

# EPA-ng/gappa outputs
epa_results/
gappa_output/

# Python
__pycache__/
*.py[cod]
.Python
venv/

# System files
.DS_Store
*.log

# Input data (too large)
families/*/data/input/

# All families/ working directories (local analysis files, never push to GitHub)
families/

# Allow .gitkeep files
!**/.gitkeep
